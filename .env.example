# Copy to .env.local for local development.
# Keep real keys out of git.
RAPIDAPI_KEY=
RAPIDAPI_HOST=sofascore.p.rapidapi.com
RAPIDAPI_BASE_URL=https://sofascore.p.rapidapi.com

# Optional override for one or more comma-separated Sofascore RapidAPI paths.
# Leave blank to use the live football endpoint plus, if the ids below are set,
# the finished-results (backfill) endpoint:
# /tournaments/get-live-events?sport=football
SOFASCORE_PATHS=

# Results backfill (apidojo Sofascore). The live endpoint only returns matches
# in progress RIGHT NOW, so a finished match that already left the feed cannot be
# recovered from it. Set the World Cup unique-tournament id AND the 2026 season id
# to also poll finished matches and persist them. Find the ids from a Sofascore
# tournament URL or the apidojo /tournaments endpoints.
SOFASCORE_UNIQUE_TOURNAMENT_ID=
SOFASCORE_SEASON_ID=
# Optional: override the backfill path template ({tournamentId}/{seasonId}/{page})
# and how many pages of recent results to pull (default 2).
SOFASCORE_RESULTS_PATH=
SOFASCORE_RESULTS_PAGES=2

# The refresh cadence is dynamic and hard-coded: every 30 seconds while a match
# is live, every 45 minutes when nothing is in progress. There is no override.
PORT=4173
HOST=127.0.0.1

# Finished-result fallback used when no live API key is configured.
# By default the app reads ./seed-results.json (operator-maintained, scores copied
# verbatim from a cited source — never generated). Set RESULT_SEED_JSON to inline
# JSON of the same shape to override the file (e.g. for a serverless deploy).
RESULT_SEED_JSON=
