# Copy to .env.local for local development.
# Keep real keys out of git.
RAPIDAPI_KEY=
RAPIDAPI_HOST=sofascore.p.rapidapi.com
RAPIDAPI_BASE_URL=https://sofascore.p.rapidapi.com

# Optional override for one or more comma-separated Sofascore RapidAPI paths.
# Leave blank to use the live football endpoint:
# /tournaments/get-live-events?sport=football
SOFASCORE_PATHS=

# Server/API cache interval in seconds.
REFRESH_INTERVAL_SECONDS=60
PORT=4173
HOST=127.0.0.1
