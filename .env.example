# Copy to .env.local for local development.
# Keep real keys out of git.
RAPIDAPI_KEY=
RAPIDAPI_HOST=sofascore.p.rapidapi.com
RAPIDAPI_BASE_URL=https://sofascore.p.rapidapi.com

# World Cup on Sofascore is unique tournament 16.
SOFASCORE_UNIQUE_TOURNAMENT_ID=16

# Set one or more comma-separated Sofascore RapidAPI paths after verifying them
# in the RapidAPI Sofascore playground. Leave blank to use verified schedule mode.
# Example after confirming the endpoint exists for the active season:
# SOFASCORE_PATHS=/tournaments/get-events?uniqueTournamentId=16&seasonId=YOUR_SEASON_ID
SOFASCORE_PATHS=

# Server/API cache interval in seconds.
REFRESH_INTERVAL_SECONDS=60
PORT=4173
HOST=127.0.0.1
